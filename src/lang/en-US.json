					"logout": {
						"display-text": "Logout",
						"list-name": "Logout",
						"description": "Logout the user"
					},
					"get-entitlements": {
						"display-text": "Get Entitlements",
						"list-name": "Get Entitlements",
						"description": "Retrieve the user's entitlements"
					},
					"get-offers": {
						"display-text": "Get Offers",
						"list-name": "Get Offers",
						"description": "Refresh the store offers"
					},
					"plan-checkout": {
						"display-text": "Plan offer {0}",
						"list-name": "Plan offer",
						"description": "Plan an offer for checkout",
						"params": {
							"offerId": {
								"name": "offerId",
								"desc": "The Offer ID to checkout"
							}
						}
					},
					"checkout": {
						"display-text": "Checkout {0}",
						"list-name": "Checkout",
						"description": "Checkout the offers previously planned",
						"params": {
							"tag": {
								"name": "tag",
								"desc": "Tag for the purchase"
							}
						}
					}
				},
				"expressions": {
					"configuration": {
						"description": "Return the SDK configuration as a JSON string",
						"translated-name": "Configuration"
					},
					"last-error": {
						"description": "Return the last error receive",
						"translated-name": "LastError"
					},
					"get-account-id": {
						"description": "Return the account id of the user.",
						"translated-name": "AccountId"
					},
					"get-username": {
						"description": "Return the Epic Username of the user",
						"translated-name": "Username"
					},
					"get-logging-status": {
						"description": "Return the latest state of the login. Can be 'inProgress', 'loggedIn' or 'loggedOut'",
						"translated-name": "LoginState"
					},
					"get-token": {
						"description": "Return the encoded token for the user.",
						"translated-name": "Token"
					},

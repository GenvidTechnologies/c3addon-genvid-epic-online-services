						"description": "Returns the specified entitlement as a JSON object",
						"translated-name": "EntitlementByIndex",
						"params": {
							"index": {
								"desc": "The index of the entitlement",
								"name": "index"
							}
						}
					},
					"entitlement-by-id": {
						"description": "Returns the specified entitlement as a JSON object",
						"translated-name": "EntitlementById",
						"params": {
							"id": {
								"desc": "The id of the entitlement",
								"name": "id"
							}
						}
					},
					"entitlement-by-name": {
						"description": "Returns the specified entitlement as a JSON object",
						"translated-name": "EntitlementByName",
						"params": {
							"name": {
								"desc": "The name of the entitlement",
								"name": "name"
							}
						}
					},
					"offers": {
						"description": "Returns all offers as JSON object",
						"translated-name": "Offers"
					},
					"offer-by-id": {
						"description": "Returns the specified offer as a JSON object",
						"translated-name": "OfferById",
						"params": {
							"id": {
								"desc": "The id of the offer",
								"name": "id"
							},
							"withItems": {
								"desc": "1 to included Items, 0 otherwise",
								"name": "withItems"
							}
						}
					},
					"offers-count": {
						"description": "Returns the number of offers",
						"translated-name": "OffersCount"
					},
					"offer-by-index": {
						"description": "Returns the specified offer as a JSON object",
						"translated-name": "OfferByIndex",
						"params": {
							"index": {
								"desc": "The index of the offer",
								"name": "index"
							},
							"withItems": {
								"desc": "1 to included Items, 0 otherwise",
								"name": "withItems"
							}
						}
					},
					"offer-items-by-index": {
						"description": "Returns the list of items in the specified offer",
						"translated-name": "OfferItemsByIndex",
						"params": {
							"index": {
								"desc": "The index of the offer",
								"name": "index"
							}
						}
					},
					"offer-items-count-by-index": {
						"description": "Returns the number of items in the specified offer",
						"translated-name": "OfferItemsCountByIndex",
						"params": {
							"index": {
								"desc": "The index of the offer",
								"name": "index"
							}
						}
					},
					"offer-item-by-index": {
						"description": "Returns an item in the specified offer",
						"translated-name": "OfferItemByIndex",
						"params": {
							"offerIndex": {
								"desc": "The index of the offer",
								"name": "index"
							},
							"itemIndex": {
								"desc": "The index of the item",
								"name": "index"
							}
						}
					},
					"offer-items-by-id": {
						"description": "Returns the list of items in the specified offer",
						"translated-name": "OfferItemsById",
						"params": {
							"id": {
								"desc": "The id of the offer",
								"name": "id"
							}
						}
					},
					"offer-items-count-by-id": {
						"description": "Returns the number of items in the specified offer",
						"translated-name": "OfferItemsCountById",
						"params": {
							"id": {
								"desc": "The id of the offer",
								"name": "id"
							}
						}
					},
					"offer-item-by-id": {
						"description": "Returns an item in the specified offer",
						"translated-name": "OfferItemById",
						"params": {
							"offerId": {
								"desc": "The id of the offer",
								"name": "index"
							},
							"itemIndex": {
								"desc": "The index of the item",
								"name": "index"
							}
						}
					},
					"transaction": {
						"description": "Returns the last transaction as JSON",
						"translated-name": "Transaction"
					},
					"transaction-id": {
						"description": "Returns the last transaction Id",
						"translated-name": "TransactionId"
					},
					"transaction-tag": {
						"description": "Returns the last transaction tag",
						"translated-name": "TransactionTag"
					},
					"transaction-entitlements": {
						"description": "Returns the new entitlements as JSON",
						"translated-name": "TransactionEntitlements"
					},
					"transaction-entitlements-count": {
						"description": "Returns the number of new entitlements in that transaction",
						"translated-name": "TransactionEntitlementsCount"
					},
					"transaction-entitlement-by-index": {
						"description": "Returns the new entitlement specified as JSON",
						"translated-name": "TransactionEntitlementByIndex",
						"params": {
							"index": {
								"name": "index",
								"desc": "Index of the entitlement"
							}
						}
					}
				},
				"debugger": {
					"title": "Genvid EOS",
					"initialized": "Initialized",
					"console-log-level": "Log Level",
					"loaded": "Configuration Loaded",
					"product-id": "Product Id",
					"product-name": "Product Name",
					"product-version": "Product Version",
					"sandbox-id": "Sandbox Id",
					"deployment-id": "Deployment Id",
					"client-id": "Client Id",
					"client-secret": "Client Secret",
					"auth": {
						"title": "Auth",
						"state": "Login Status",
						"logged": "Logged In",
						"username": "Username",
						"accountid": "Account Id",
						"token": "Token"
					},
					"ecom": {
						"entitlements": {
							"title": "User Entitlements"
						},
						"offers": {
							"title": "Store Offers"
						},
						"checkout": {
							"title": "Checkout Transaction",

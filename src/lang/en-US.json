{
	"$schema": "../../SDK/plugin-sdk/v2/plugin.lang.schema.json",
	"languageTag": "en-US",
	"fileDescription": "Strings for Genvid EOS.",
	"text": {
		"plugins": {
			"genvid_eos": {
				"name": "GenvidEOS",
				"description": "Integration of Epic Online Services API.",
				"help-url": "https://bitbucket.org/genvidtech/c3addon-genvid-epic-online-services",
				"properties": {
					"console-log-level": {
						"name": "Console Log Level",
						"desc": "Forward native logs to that console log level",
						"items": {
							"error": "Error",
							"warn": "Warning",
							"info": "Info",
							"debug": "Debug",
							"none": "None"
						}
					},
					"offers-available-only": {
						"name": "Only available offers",
						"desc": "Filter out non-available offers when enabled."
					}
				},
				"aceCategories": {
					"sdk": "SDK",
					"auth": "Authentication",
					"ecom-entitlements": "Entitlements",
					"ecom-offers": "Offers",
					"ecom-checkout": "Purchases"
				},
				"conditions": {
					"configuration-loaded": {
						"display-text": "Configuration Loaded",
						"list-name": "Is Configuration Loaded",
						"description": "True if the default configuration has been loaded"
					},
					"on-configuration-loaded": {
						"display-text": "On Configuration Loaded",
						"list-name": "On Configuration Loaded",
						"description": "Trigger when the default configuration has been loaded"
					},
					"on-initialization-success": {
						"display-text": "On Initialization Successful",
						"list-name": "On Initialization Successful",
						"description": "Trigger when the SDK has been initialized"
					},
					"on-initialization-error": {
						"display-text": "On Initialization Error",
						"list-name": "On Initialization Error",
						"description": "Trigger when an error happens during initialization"
					},
					"on-login-persistent-success": {
						"display-text": "On Persistent Login Successful",
						"list-name": "On Persistent Login Successful",
						"description": "Trigger when the Persistent Login is successful"
					},
					"on-login-persistent-error": {
						"display-text": "On Persistent Login Error",
						"list-name": "On Persistent Login Error",
						"description": "Trigger when an error occured during Persistent Login"
					},
					"on-login-portal-success": {
						"display-text": "On Portal Login Successful",
						"list-name": "On Portal Login Successful",
						"description": "Trigger when the Portal Login is successful"
					},
					"on-login-portal-error": {
						"display-text": "On Portal Login Error",
						"list-name": "On Portal Login Error",
						"description": "Trigger when an error occured during Portal Login"
					},
					"on-logout-success": {
						"display-text": "On Successful Logout",
						"list-name": "On Successful Logout",
						"description": "Trigger when Logout has completed"
					},
					"on-logout-error": {
						"display-text": "On Logout Error",
						"list-name": "On Logout Error",
						"description": "Trigger when an error occured during Logout"
					},
					"on-login-state-change": {
						"display-text": "On Login State Changed",
						"list-name": "On Login State Changed",
						"description": "Trigger when the login state change"
					},
					"is-logged-in": {
						"display-text": "Is Logged In",
						"list-name": "Is Logged In",
						"description": "Return if the user is actually logged in"
					},
					"is-initialized": {
						"display-text": "Is Initialized",
						"list-name": "Is Initialized",
						"description": "Returns if the SDK has been initialized properly"
					},
					"on-get-entitlements-success": {
						"display-text": "On Get Entitlements",
						"list-name": "On Get Entitlements",
						"description": "Calls on successfull retrieval of user's entitlements"
					},
					"on-get-entitlements-error": {
						"display-text": "On Get Entitlements failure",
						"list-name": "On Get Entitlements error",
						"description": "Calls if an error happens when retrieving user's entitlements"
					},
					"on-get-offers-success": {
						"display-text": "On Get Offers",
						"list-name": "On Get Offers",
						"description": "Calls when the list of offers is retrieved successfully"
					},
					"on-get-offers-error": {
						"display-text": "On Get Offers failure",
						"list-name": "On Get Offers failure",
						"description": "Calls when an error occured while retrieving offers"
					},
					"on-checkout-success": {
						"display-text": "On Checkout {0}",
						"list-name": "On Checkout",
						"description": "Calls when the purchase is successful",
						"params": {
							"tag": {
								"name": "tag",
								"desc": "Tag of the purchase"
							}
						}
					},
					"on-checkout-error": {
						"display-text": "On Checkout {0} failure",
						"list-name": "On Checkout failure",
						"description": "Calls when a purchase fail",
						"params": {
							"tag": {
								"name": "tag",
								"desc": "Tag of the purchase"
							}
						}
					},
					"on-checkout-cancelled": {
						"display-text": "On Checkout {0} cancellation",
						"list-name": "On Checkout cancellation",
						"description": "Calls when a purchase has been cancelled",
						"params": {
							"tag": {
								"name": "tag",
								"desc": "Tag of the purchase"
							}
						}
					},
					"on-any-checkout-success": {
						"display-text": "On Any Checkout",
						"list-name": "On Any Checkout",
						"description": "Calls when any purchase is successful"
					},
					"on-any-checkout-error": {
						"display-text": "On Any Checkout failure",
						"list-name": "On Any Checkout failure",
						"description": "Calls when any purchase fail"
					},
					"on-any-checkout-cancelled": {
						"display-text": "On Any Checkout cancellation",
						"list-name": "On Any Checkout cancellation",
						"description": "Calls when any purchase has been cancelled"
					}
				},
				"actions": {
					"set-product-id": {
						"list-name": "Set Product Id",
						"display-text": "Set Product Id to {0}",
						"description": "Set the product Id.",
						"params": {
							"product-id": {
								"name": "Product Id",
								"desc": "The Product Id"
							}
						}
					},
					"set-product-name": {
						"list-name": "Set Product Name",
						"display-text": "Set Product Name to {0}",
						"description": "Set the product name. Default to project name.",
						"params": {
							"product-name": {
								"name": "Product Name",
								"desc": "The Product Name"
							}
						}
					},
					"set-product-version": {
						"list-name": "Set Product Version",
						"display-text": "Set Product Version to {0}",
						"description": "Set the product version. Default to project version.",
						"params": {
							"product-version": {
								"name": "Product Version",
								"desc": "The Product Version"
							}
						}
					},
					"set-sandbox-id": {
						"list-name": "Set Sandbox Id",
						"display-text": "Set Sandbox to {0}",
						"description": "Set the sandbox id.",
						"params": {
							"sandbox-id": {
								"name": "Sandbox Id",
								"desc": "The Sandbox Id"
							}
						}
					},
					"set-deployment-id": {
						"list-name": "Set Deployment Id",
						"display-text": "Set Deployment to {0}",
						"description": "Set the deployment id.",
						"params": {
							"deployment-id": {
								"name": "Deployment Id",
								"desc": "The Deployment Id"
							}
						}
					},
					"set-client-id": {
						"list-name": "Set Client Id",
						"display-text": "Set Client Id to {0}",
						"description": "Set the client id.\nATTENTION: the client id must match the one use in eos_config.json. Changing it can make the login failed.",
						"params": {
							"client-id": {
								"name": "Client Id",
								"desc": "The Client Id"
							}
						}
					},
					"set-client-secret": {
						"list-name": "Set Client Secret",
						"display-text": "Set Client Secret to {0}",
						"description": "Set the client secret.",
						"params": {
							"client-secret": {
								"name": "Client Secret",
								"desc": "The Client Secret"
							}
						}

						"display-text": "Try Persistent Login",
						"list-name": "Persistent Login",
						"description": "Try to login with the persistent credentials from last login."
					},
					"login-portal": {
						"display-text": "Login",
						"list-name": "Login with Account Portal",
						"description": "Launch a browser session to login with Epic Portal"
